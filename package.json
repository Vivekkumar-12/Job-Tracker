{
  "name": "job-hunt-hub",
  "private": true,
  "version": "1.0.0",
  "description": "Root workspace for Job Hunt Hub (backend + frontend)",
  "scripts": {
    "setup": "npm --prefix backend install && npm --prefix frontend install",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend start",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "dev": "concurrently -k -n BE,FE -c blue,green \"npm:backend:dev\" \"npm:frontend:dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
